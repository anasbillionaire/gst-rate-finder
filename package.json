{
  "name": "india-gst-rate-finder-api",
  "version": "1.0.0",
  "description": "India GST rate finder API using supplied HSN/SAC and GST goods rate files.",
  "main": "dist/src/server.js",
  "type": "module",
  "scripts": {
    "import:data": "tsx src/importers/importData.ts",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "gst",
    "hsn",
    "india",
    "api",
    "tax"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fuse.js": "^7.1.0",
    "helmet": "^8.1.0",
    "pdf-parse": "^2.4.5",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@vercel/node": "^5.7.13",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
